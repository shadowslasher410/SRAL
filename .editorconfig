root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4

[*.{c,h,cpp,hpp,m,mm,idl}]
indent_style = tab
indent_size = 4
tab_width = 4
max_line_length = 120

[*.java]
indent_style = tab
indent_size = 4

[*.go]
indent_style = tab
tab_width = 4

[*.py]
indent_style = space
indent_size = 4

[{CMakeLists.txt,*.cmake,meson.build,meson_options.txt,*.preset}]
indent_style = tab
indent_size = 4

[*.{json,json5,presets,build,gyp,xml,pro,yaml,yml}]
indent_style = space
indent_size = 2

[*.cs]
indent_style = space
indent_size = 4
csharp_style_var_elsewhere = true:suggestion

[*.rs]
indent_style = space
indent_size = 4

[*.dart]
indent_style = space
indent_size = 2

[*.{js,cjs,mjs}]
indent_style = space
indent_size = 2

[*.lua]
indent_style = space
indent_size = 2

[{*.csproj,Cargo.toml,pyproject.toml,package.json,go.mod,go.work}]
indent_style = space
indent_size = 4

[*.{md,txt}]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false
