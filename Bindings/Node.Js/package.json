{
  "name": "sral-node",
  "version": "1.0.0",
  "description": "Node.js Node-API bridge bindings for SRAL",
  "main": "lib/sral.js",
  "scripts": {
    "install": "cmake-js compile",
    "compile": "cmake-js compile -DSRAL_CORE_LIB_DIR=\"../../out/build/Release\"",
    "compile:debug": "cmake-js compile --debug -DSRAL_CORE_LIB_DIR=\"../../out/build/Debug\"",
    "compile:win-x64-release": "cmake-js compile -DSRAL_CORE_LIB_DIR=\"../../out/build/x64-Release\"",
    "compile:win-x64-debug": "cmake-js compile --debug -DSRAL_CORE_LIB_DIR=\"../../out/build/x64-Debug\"",
    "compile:android-arm64": "cmake-js compile -DANDROID_PLATFORM=android-21 -DANDROID_ABI=arm64-v8a",
    "compile:android-x86_64": "cmake-js compile -DANDROID_PLATFORM=android-21 -DANDROID_ABI=x86_64",
    "compile:ios": "cmake-js compile -G Xcode -DCMAKE_SYSTEM_NAME=iOS -DCMAKE_OSX_ARCHITECTURES=arm64",
    "compile:ios-sim": "cmake-js compile -G Xcode -DCMAKE_SYSTEM_NAME=iOS -DCMAKE_OSX_SYSROOT=iphonesimulator -DCMAKE_OSX_ARCHITECTURES=x86_64",
    "clean": "cmake-js clean",
    "test": "node Example.js"
  },
  "dependencies": {
    "node-addon-api": "^8.9.0"
  },
  "devDependencies": {
    "cmake-js": "^8.0.0"
  }
}