{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 3,
    "patch": 1
  },
  "configurePresets": [
    {
      "name": "base-superbuild",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}"
    },
    {
      "name": "base-release",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "ON",
        "BUILD_TESTS": "OFF",
        "BUILD_BINDINGS": "OFF"
      }
    },
    {
      "name": "base-debug",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_SHARED_LIBS": "OFF",
        "BUILD_TESTS": "ON",
        "BUILD_BINDINGS": "OFF"
      }
    },
    {
      "name": "desktop-release",
      "inherits": [ "base-superbuild", "base-release" ],
      "cacheVariables": {
        "TARGET_DESKTOP": "ON",
        "TARGET_CHROMEVOX": "OFF",
        "TARGET_ANDROID": "OFF",
        "TARGET_IOS": "OFF"
      }
    },
    {
      "name": "desktop-debug",
      "inherits": [ "base-superbuild", "base-debug" ],
      "cacheVariables": {
        "TARGET_DESKTOP": "ON",
        "TARGET_CHROMEVOX": "OFF",
        "TARGET_ANDROID": "OFF",
        "TARGET_IOS": "OFF"
      }
    },
    {
      "name": "chromevox-release",
      "inherits": [ "base-superbuild", "base-release" ],
      "cacheVariables": {
        "TARGET_DESKTOP": "OFF",
        "TARGET_CHROMEVOX": "ON",
        "TARGET_ANDROID": "OFF",
        "TARGET_IOS": "OFF",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "chromevox-debug",
      "inherits": [ "base-superbuild", "base-debug" ],
      "cacheVariables": {
        "TARGET_DESKTOP": "OFF",
        "TARGET_CHROMEVOX": "ON",
        "TARGET_ANDROID": "OFF",
        "TARGET_IOS": "OFF",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "android-release",
      "inherits": [ "base-superbuild", "base-release" ],
      "cacheVariables": {
        "TARGET_DESKTOP": "OFF",
        "TARGET_CHROMEVOX": "OFF",
        "TARGET_ANDROID": "ON",
        "TARGET_IOS": "OFF"
      }
    },
    {
      "name": "android-debug",
      "inherits": [ "base-superbuild", "base-debug" ],
      "cacheVariables": {
        "TARGET_DESKTOP": "OFF",
        "TARGET_CHROMEVOX": "OFF",
        "TARGET_ANDROID": "ON",
        "TARGET_IOS": "OFF"
      }
    },
    {
      "name": "ios-release",
      "inherits": [ "base-superbuild", "base-release" ],
      "cacheVariables": {
        "TARGET_DESKTOP": "OFF",
        "TARGET_CHROMEVOX": "OFF",
        "TARGET_ANDROID": "OFF",
        "TARGET_IOS": "ON",
        "BUILD_SHARED_LIBS": "OFF"
      }
    },
    {
      "name": "ios-debug",
      "inherits": [ "base-superbuild", "base-debug" ],
      "cacheVariables": {
        "TARGET_DESKTOP": "OFF",
        "TARGET_CHROMEVOX": "OFF",
        "TARGET_ANDROID": "OFF",
        "TARGET_IOS": "ON",
        "BUILD_SHARED_LIBS": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "desktop-release", "configurePreset": "desktop-release" },
    { "name": "desktop-debug", "configurePreset": "desktop-debug" },
    { "name": "chromevox-release", "configurePreset": "chromevox-release" },
    { "name": "chromevox-debug", "configurePreset": "chromevox-debug" },
    { "name": "android-release", "configurePreset": "android-release" },
    { "name": "android-debug", "configurePreset": "android-debug" },
    { "name": "ios-release", "configurePreset": "ios-release" },
    { "name": "ios-debug", "configurePreset": "ios-debug" }
  ]
}