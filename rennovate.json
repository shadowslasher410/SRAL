{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "groupName": "all-actions",
      "matchManagers": ["github-actions"]
    }
  ]
}
